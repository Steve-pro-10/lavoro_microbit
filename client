is_client = False
is_server = False
is_configured = False
quorum = 0
votato = False
binario = ""
conf_is_finished = False
radio.on()
basic.show_string("?")
def vota():
        
    radio.set_group(36)
    if not votato:
        if input.button_is_pressed(Button.A):
            radio.send_number(1)#si
            basic.show_icon(IconNames.YES)
            votato = True
        elif input.button_is_pressed(Button.B):
            radio.send_string("NO")
            basic.show_icon(IconNames.NO)
            votato = True
        

def server():
    #inserire in binario il quorum
    pass
    
basic.show_string("choose")
def on_button_pressed_a():

    global is_configured, binario

    if not is_configured:
        is_client = True
        is_configured = True
    if is_configured:
        binario += '1'
input.on_button_pressed(Button.A, on_button_pressed_a)

def on_button_pressed_b():
    global server, is_configured,binario
    if not is_configured:
        is_server = True
        is_configured = True
    if is_server:
        binario += '0'

input.on_button_pressed(Button.B, on_button_pressed_b)

def on_button_pressed_ab():
    global binario,quorum
    if not conf_is_finished:
        conf_is_finished = True
        binario = binario[::-1]
        decimale = int(binario, 2)
        quorum = decimale
        
input.on_button_pressed(Button.AB, on_button_pressed_ab)

